{
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "http://resala.runasp.net/api/v1/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "http://resala.runasp.net/v1/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "http://resala.runasp.net/api/$1"
    },
    {
      "source": "/Account/(.*)",
      "destination": "http://resala.runasp.net/Account/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
